# ── Groq LLM ──────────────────────────────────────────────────────────────────
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Stripe (test mode) ────────────────────────────────────────────────────────
# 1. Create account at https://dashboard.stripe.com
# 2. Switch to TEST mode (toggle in top-left)
# 3. Go to Developers → API keys → copy "Secret key" (starts with sk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# 4. Create two Products in Stripe Dashboard → Products:
#    - "Notelift Pro"  → $15/mo  → copy Price ID (price_xxx)
#    - "Notelift Team" → $39/mo  → copy Price ID (price_xxx)
STRIPE_PRO_PRICE_ID=price_your_pro_price_id_here
STRIPE_TEAM_PRICE_ID=price_your_team_price_id_here

# 5. Set up webhook:
#    - Install Stripe CLI: https://stripe.com/docs/stripe-cli
#    - Run: stripe listen --forward-to localhost:8000/api/stripe/webhook
#    - Copy the webhook signing secret (whsec_xxx) printed by the CLI
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
